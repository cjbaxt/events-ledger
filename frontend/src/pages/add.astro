---
import "../styles/global.css";
import Nav from "../components/Nav";
import EditorUnlock from "../components/EditorUnlock";
import AddEvent from "../components/AddEvent";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Add event — Events Ledger</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Playfair+Display:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white min-h-screen">
    <EditorUnlock client:load />
    <Nav current="/add" client:load />
    <main class="max-w-lg mx-auto px-4 pt-20 pb-32 md:pb-12">
      <AddEvent client:load />
    </main>
  </body>
</html>
