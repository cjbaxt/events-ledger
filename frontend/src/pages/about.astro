---
import "../styles/global.css";
import Nav from "../components/Nav";
import EditorUnlock from "../components/EditorUnlock";
import EventDetailPanel from "../components/EventDetailPanel";
import IconLegend from "../components/IconLegend";
import fs from "fs";
import path from "path";

const raw = fs.readFileSync(path.resolve("src/content/about.md"), "utf-8");
const paragraphs = raw.split(/\n\n+/).map(p => p.trim()).filter(Boolean);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}${import.meta.env.PUBLIC_STATIC_DATA === "true" ? "favicon.png" : "favicon-local.png"}`} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}${import.meta.env.PUBLIC_STATIC_DATA === "true" ? "favicon.svg" : "favicon-local.svg"}`} />
    {import.meta.env.PUBLIC_STATIC_DATA === "true" && <link rel="alternate icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />}
    {import.meta.env.PUBLIC_STATIC_DATA === "true" && <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />}
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>About — Events Ledger</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Playfair+Display:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white min-h-screen">
    <EditorUnlock client:load />
    <Nav current="/about" client:load />
    <main class="max-w-2xl mx-auto px-4 pt-4 md:pt-20 pb-24 md:pb-8">
      <p class="font-serif text-2xl text-neutral-900 mt-4 mb-8">About</p>
      <div class="space-y-5 text-sm text-neutral-700 leading-relaxed">
        {paragraphs.map(p => <p>{p}</p>)}
      </div>
      <IconLegend client:load />
    </main>
    <EventDetailPanel client:load />
  </body>
</html>
